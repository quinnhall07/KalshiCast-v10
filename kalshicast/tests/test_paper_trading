class TestEnrichedAlert:
    """Verify the enriched PAPER_NO_POSITIONS alert computes correct stats."""

    def test_alert_details_with_no_edge(self):
        """Alert should show zero kelly_positive when no edge exists."""
        best_bets_paper = [
            {"p_win": 0.30, "c_vwap": 0.32, "contract_price": 0.32,
             "gate_flags": {"edge": False, "spread": True, "skill": True, "lead": True, "reserved": True},
             "f_star": 0.0},
            {"p_win": 0.25, "c_vwap": 0.26, "contract_price": 0.26,
             "gate_flags": {"edge": False, "spread": True, "skill": True, "lead": True, "reserved": True},
             "f_star": 0.0},
        ]

        edges_for_alert = [
            b["p_win"] - b.get("contract_price", b.get("c_vwap", 0))
            for b in best_bets_paper
            if b.get("c_vwap") and b["c_vwap"] > 0
        ]
        gate_pass_count = sum(
            1 for b in best_bets_paper
            if all(b.get("gate_flags", {}).get(g, False)
                   for g in ("edge", "spread", "skill", "lead", "reserved"))
        )
        kelly_pass_count = sum(
            1 for b in best_bets_paper if (b.get("f_star") or 0) > 0
        )

        assert len(edges_for_alert) == 2
        assert gate_pass_count == 0  # edge gate failed for both
        assert kelly_pass_count == 0
        avg_edge = sum(edges_for_alert) / len(edges_for_alert)
        assert avg_edge < 0  # (-0.02 + -0.01) / 2 = -0.015

    def test_alert_details_with_empty_bets(self):
        """Alert should handle empty best_bets gracefully."""
        best_bets_paper = []

        edges_for_alert = [
            b["p_win"] - b.get("contract_price", b.get("c_vwap", 0))
            for b in best_bets_paper
            if b.get("c_vwap") and b["c_vwap"] > 0
        ]
        gate_pass_count = sum(
            1 for b in best_bets_paper
            if all(b.get("gate_flags", {}).get(g, False)
                   for g in ("edge", "spread", "skill", "lead", "reserved"))
        )

        assert edges_for_alert == []
        assert gate_pass_count == 0
        # avg_edge and max_edge should be None when edges_for_alert is empty
        avg_edge = round(sum(edges_for_alert) / len(edges_for_alert), 4) if edges_for_alert else None
        max_edge = round(max(edges_for_alert), 4) if edges_for_alert else None
        assert avg_edge is None
        assert max_edge is None