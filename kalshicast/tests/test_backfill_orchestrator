class TestBackfillEndToEnd:
    """Integration test: verify all phases complete in order on mock data."""

    def _empty_coverage(self):
        return {
            "observation_dates": set(),
            "forecast_dates": {},
            "error_dates": set(),
            "kalman_dates": set(),
        }

    def test_all_phases_called_in_order(self):
        """When DB is empty, all 5 phases must be invoked in order."""
        call_order = []

        def record(name, *a, **kw):
            call_order.append(name)
            return 0

        from kalshicast.backfill.orchestrator import run_backfill
        conn = MagicMock()

        with patch("kalshicast.backfill.orchestrator.get_backfill_coverage",
                   return_value=self._empty_coverage()), \
             patch("kalshicast.backfill.orchestrator.load_all_observations",
                   side_effect=lambda *a, **k: record("observations")), \
             patch("kalshicast.backfill.orchestrator.get_backfill_coverage",
                   return_value=self._empty_coverage()), \
             patch("kalshicast.backfill.orchestrator.load_all_forecasts",
                   side_effect=lambda *a, **k: record("forecasts")), \
             patch("kalshicast.backfill.orchestrator.build_backfill_errors",
                   side_effect=lambda *a, **k: record("errors")), \
             patch("kalshicast.backfill.orchestrator.replay_kalman_filters",
                   side_effect=lambda *a, **k: record("kalman")), \
             patch("kalshicast.backfill.orchestrator.refresh_bss_matrix",
                   side_effect=lambda *a, **k: record("bss")):

            # Patch get_backfill_coverage to always return empty
            import kalshicast.backfill.orchestrator as orch
            original_cov = orch.get_backfill_coverage
            orch.get_backfill_coverage = lambda *a, **k: self._empty_coverage()

            try:
                result = run_backfill(conn, "2024-01-01", "2024-01-07")
            finally:
                orch.get_backfill_coverage = original_cov

        assert "phases" in result
        assert result["start_date"] == "2024-01-01"
        assert result["end_date"]   == "2024-01-07"