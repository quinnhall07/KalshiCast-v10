# kalshicast/tests/test_backfill_orchestrator.py
import pytest
from unittest.mock import patch, MagicMock, call
from datetime import date


class TestOrchestratorPhaseOrder:
    """Verify that phases run in the required order and are skipped when coverage exists."""

    def _make_mock_conn(self):
        conn = MagicMock()
        conn.cursor.return_value.__enter__ = lambda s: s
        conn.cursor.return_value.__exit__ = MagicMock(return_value=False)
        conn.cursor.return_value.execute = MagicMock(return_value=None)
        conn.cursor.return_value.fetchone = MagicMock(return_value=None)
        conn.cursor.return_value.fetchall = MagicMock(return_value=[])
        conn.cursor.return_value.__iter__ = MagicMock(return_value=iter([]))
        return conn

    def test_orchestrator_imports(self):
        from kalshicast.backfill.orchestrator import run_backfill
        assert callable(run_backfill)

    def test_run_backfill_accepts_date_window(self):
        """run_backfill should accept start/end date strings without raising."""
        from kalshicast.backfill.orchestrator import run_backfill
        conn = self._make_mock_conn()
        with patch("kalshicast.backfill.orchestrator.load_all_observations", return_value=0), \
             patch("kalshicast.backfill.orchestrator.load_all_forecasts", return_value=0), \
             patch("kalshicast.backfill.orchestrator.build_backfill_errors", return_value=0), \
             patch("kalshicast.backfill.orchestrator.replay_kalman_filters", return_value=0), \
             patch("kalshicast.backfill.orchestrator.refresh_bss_matrix", return_value=0), \
             patch("kalshicast.backfill.orchestrator.get_backfill_coverage",
                   return_value={"observation_dates": set(), "forecast_dates": {},
                                 "error_dates": set(), "kalman_dates": set()}):
            result = run_backfill(conn, "2023-01-01", "2023-01-05")
        assert isinstance(result, dict)
        assert "phases" in result

    def test_observation_phase_skipped_when_dates_covered(self):
        """If all dates already have observations, load_all_observations is not called."""
        from kalshicast.backfill.orchestrator import run_backfill
        conn = self._make_mock_conn()
        all_dates = {f"2023-01-0{i}" for i in range(1, 6)}
        with patch("kalshicast.backfill.orchestrator.load_all_observations") as mock_obs, \
             patch("kalshicast.backfill.orchestrator.load_all_forecasts", return_value=0), \
             patch("kalshicast.backfill.orchestrator.build_backfill_errors", return_value=0), \
             patch("kalshicast.backfill.orchestrator.replay_kalman_filters", return_value=0), \
             patch("kalshicast.backfill.orchestrator.refresh_bss_matrix", return_value=0), \
             patch("kalshicast.backfill.orchestrator.get_backfill_coverage",
                   return_value={"observation_dates": all_dates, "forecast_dates": {},
                                 "error_dates": set(), "kalman_dates": set()}):
            run_backfill(conn, "2023-01-01", "2023-01-05")
        mock_obs.assert_not_called()

